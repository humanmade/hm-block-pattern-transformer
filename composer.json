{
	"name": "humanmade/block-pattern-transformer",
	"description": "Pattern-based content transformation for WordPress block migrations",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Human Made",
			"homepage": "https://humanmade.com"
		}
	],
	"require": {
		"php": ">=8.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.5",
		"brain/monkey": "^2.6",
		"humanmade/coding-standards": "dev-main"
	},
	"scripts": {
		"test": "phpunit",
		"lint": "phpcs"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
